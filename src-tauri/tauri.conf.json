{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora",
  "version": "2.2.13",
  "identifier": "com.aurora.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurora",
        "width": 1100,
        "height": 750,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://pgpbabflshcdhzitqnmf.supabase.co https://api.open-meteo.com https://docs.google.com https://calendar.google.com; img-src 'self' asset: http://asset.localhost data: https://pgpbabflshcdhzitqnmf.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Nguyen",
    "resources": [],
    "shortDescription": "App make by Nguyen Vang",
    "copyright": "Copyright © 2026 Aurora",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
